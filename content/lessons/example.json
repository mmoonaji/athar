  "contentBlocks": [
    {
      "orderIndex": 0,
      "type": "heading",
      "level": 2,
      "text": "معنى التوحيد في الإسلام"
    },
    {
      "orderIndex": 1,
      "type": "paragraph",
      "text": "التوحيد هو إفراد الله سبحله وتعالى بالعبادة، والاعتقاد بأنه الخالق والرازق والمدبر لكل شؤون الكون دون شريك."
    },
    {
      "orderIndex": 2,
      "type": "quran_verse",
      "surah": 112,
      "ayah": 1,
      "text": "قُلْ هُوَ اللَّهُ أَحَدٌ",
      "translation": "قل -أيها الرسول-: هو الله المنفرد بالوحدانية والجلال."
    },
    {
      "orderIndex": 3,
      "type": "hadith",
      "text": "بُنِيَ الإِسْلاَمُ عَلَى خَمْسٍ: شَهَادَةِ أَنْ لاَ إِلَهَ إِلاَّ اللَّهُ...",
      "source": "رواه البخاري، رقم ٨"
    },
    {
      "orderIndex": 4,
      "type": "scholar_note",
      "scholarName": "الإمام ابن تيمية",
      "text": "التوحيد أول الدين وآخره، وهو مفتاح الجنة الذي لا يدخلها أحد إلا به."
    },
    {
      "orderIndex": 5,
      "type": "takeaway",
      "text": "التوحيد هو جوهر الإسلام والأساس الذي تقبل به جميع الأعمال الصالحة."
    },
    {
      "orderIndex": 6,
      "type": "reflection_question",
      "text": "كيف ينعكس اعتقادك بوحدانية الله على تعاملاتك اليومية ويقينك بالرزق؟"
    }
  ],
